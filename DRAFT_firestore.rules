rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity-specific Validation Helpers
    function isValidUser(data) {
      return data.get('uid', '') is string && data.get('uid', '').size() <= 128 && data.get('uid', '') == request.auth.uid &&
             data.get('name', '') is string && data.get('name', '').size() <= 128 &&
             data.get('email', '') is string && data.get('email', '').size() <= 256 &&
             data.get('phoneNumber', '') is string && data.get('phoneNumber', '').size() <= 32 &&
             data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 128;
    }

    function isValidAppointment(data) {
      return data.get('id', '') is string && data.get('id', '').size() <= 128 &&
             data.get('doctorId', '') is string && data.get('doctorId', '').size() <= 128 &&
             data.get('doctorName', '') is string && data.get('doctorName', '').size() <= 128 &&
             data.get('departmentId', '') is string && data.get('departmentId', '').size() <= 128 &&
             data.get('departmentName', '') is string && data.get('departmentName', '').size() <= 128 &&
             data.get('date', '') is string && data.get('date', '').size() <= 64 &&
             data.get('timeSlot', '') is string && data.get('timeSlot', '').size() <= 64 &&
             data.get('patientName', '') is string && data.get('patientName', '').size() <= 128 &&
             data.get('patientPhone', '') is string && data.get('patientPhone', '').size() <= 64 &&
             data.get('patientEmail', '') is string && data.get('patientEmail', '').size() <= 256 &&
             data.get('status', '') is string && (data.get('status', '') == 'Confirmed' || data.get('status', '') == 'Cancelled') &&
             data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 128 &&
             (data.get('notes', null) == null || (data.get('notes', '') is string && data.get('notes', '').size() <= 2048)) &&
             (data.get('userId', null) == null || (data.get('userId', '') is string && data.get('userId', '').size() <= 128));
    }

    // Collection: Users Profile Map
    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid && isValidId(userId);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && isValidUser(incoming()) && incoming().get('createdAt', '') == existing().get('createdAt', '') && incoming().get('uid', '') == existing().get('uid', '');
      allow delete: if false;
    }

    // Collection: Clinical Appointment Bookings
    match /appointments/{appointmentId} {
      allow get: if (existing().get('userId', null) == null || (isSignedIn() && existing().get('userId', null) == request.auth.uid)) && isValidId(appointmentId);
      allow list: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
      allow create: if (incoming().get('userId', null) == null || (isSignedIn() && incoming().get('userId', null) == request.auth.uid)) && isValidAppointment(incoming()) && isValidId(appointmentId);
      allow update: if isSignedIn() && (
                    (
                      ((existing().get('userId', null) == request.auth.uid) || 
                       (existing().get('userId', null) == null && existing().get('patientEmail', '') == request.auth.token.email)) && 
                      incoming().get('id', '') == existing().get('id', '') && 
                      incoming().get('userId', null) == existing().get('userId', null) && 
                      incoming().get('createdAt', '') == existing().get('createdAt', '') && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      (incoming().get('status', '') == 'Confirmed' || incoming().get('status', '') == 'Cancelled')
                    )
                  );
      allow delete: if isSignedIn() && (existing().get('userId', null) == request.auth.uid || (existing().get('userId', null) == null && existing().get('patientEmail', '') == request.auth.token.email)) && isValidId(appointmentId);
    }
  }
}
